{
  "name": "vladimir-photographer-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "doctor": "node scripts/doctor.js",
    "open:admin": "powershell -ExecutionPolicy Bypass -File scripts/open-admin.ps1",
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "build:frontend": "npm --prefix frontend run build",
    "copy:frontend": "node scripts/copy-frontend-dist.cjs",
    "build": "npm run build:frontend && npm run copy:frontend",
    "start": "npm --prefix backend start",
    "deploy": "npm run install:all && npm run build"
  }
}
